{
  "layout": {
    "left_pane": {
      "type": "Canvas",
      "id": "canvas_image",
      "description": "Displays the loaded image entirely or zooming, overlaid with bounding boxes / circles."
    },
    "middle_pane": {
      "type": "Frame",
      "id": "frame_controls",
      "controls": [
        {
          "id": "btn_load_image",
          "label": "Load Image",
          "type": "button",
          "default": null,
          "datatype": "event"
        },
        {
          "id": "dropdown_algo",
          "label": "Detection Method",
          "type": "dropdown",
          "default": "Hough Circle Transform",
          "options": ["Hough Circle Transform", "MinEnclosing", "Canny+Hough", "Multi-scale Fusion"],
          "datatype": "string"
        },
        {
          "id": "chk_compare",
          "label": "Enable Compare Mode",
          "type": "checkbox",
          "default": false,
          "datatype": "boolean"
        },
        {
          "id": "sld_canny_low",
          "label": "Canny Low Threshold",
          "type": "slider",
          "default": 50,
          "range": [0, 255],
          "datatype": "int"
        },
        {
          "id": "sld_canny_high",
          "label": "Canny High Threshold",
          "type": "slider",
          "default": 150,
          "range": [0, 255],
          "datatype": "int"
        },
        {
          "id": "sld_hough_dp",
          "label": "Hough dp (Resolution)",
          "type": "slider",
          "default": 1.2,
          "range": [1.0, 3.0],
          "datatype": "float",
          "step": 0.1
        },
        {
          "id": "sld_hough_min_dist",
          "label": "Min Distance b/w Centers",
          "type": "slider",
          "default": 30,
          "range": [1, 500],
          "datatype": "int"
        },
        {
          "id": "sld_hough_param1",
          "label": "Hough Param1 (Gradient Thresh)",
          "type": "slider",
          "default": 50,
          "range": [1, 300],
          "datatype": "int"
        },
        {
          "id": "sld_hough_param2",
          "label": "Hough Param2 (Accumulator Thresh)",
          "type": "slider",
          "default": 30,
          "range": [1, 200],
          "datatype": "int"
        },
        {
          "id": "sld_min_radius",
          "label": "Min Radius",
          "type": "slider",
          "default": 10,
          "range": [1, 200],
          "datatype": "int"
        },
        {
          "id": "sld_max_radius",
          "label": "Max Radius",
          "type": "slider",
          "default": 100,
          "range": [10, 500],
          "datatype": "int"
        },
        {
          "id": "btn_run",
          "label": "Run Detection",
          "type": "button",
          "default": null,
          "datatype": "event"
        },
        {
          "id": "btn_export",
          "label": "Export Results",
          "type": "button",
          "default": null,
          "datatype": "event"
        }
      ]
    },
    "right_pane": {
      "type": "Frame",
      "id": "frame_results",
      "controls": [
        {
          "id": "txt_results",
          "label": "Results Output",
          "type": "textbox",
          "default": "",
          "datatype": "string"
        },
        {
          "id": "table_metrics",
          "label": "Metrics Table",
          "type": "treeview",
          "columns": ["Method", "Circles", "Time(s)", "IoU"],
          "datatype": "tabular"
        }
      ]
    },
    "bottom_pane": {
      "type": "Frame",
      "id": "frame_status",
      "controls": [
        {
          "id": "lbl_status",
          "label": "Status Bar",
          "type": "label",
          "default": "Ready",
          "datatype": "string"
        }
      ]
    }
  }
}